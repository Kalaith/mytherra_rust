# Local MySQL for the mytherra authority server (GDD 6/8 — the DB is the save).
# Copy this file to `.env` and fill in real credentials. The server assembles a
# MySQL connection from these; the database is created on first run if absent.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mytherra_rust
DB_USER=root
DB_PASSWORD=
